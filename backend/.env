# =============================================================================
# Environment Configuration for Repo Analyser Backend
# =============================================================================

# Application
APP_NAME=repo-analyser
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/repo_analyser
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# FAISS Vector Store
FAISS_INDEX_PATH=./data/faiss_index
FAISS_DIMENSION=1536

# GitHub
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_API_BASE_URL=https://api.github.com

# AI / LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-ada-002
LLM_MODEL=gpt-4

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Clone directory for repos
REPO_CLONE_DIR=./data/repos
